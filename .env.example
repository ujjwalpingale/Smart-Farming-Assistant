# Smart Farming Assistant - Environment Configuration
# Copy this file to .env and update with your actual values

# Django Settings
# Generate a new SECRET_KEY using: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-super-secret-key-change-this-in-production

# Set to 'true' only in development environments
DEBUG=False

# Comma-separated list of allowed host domains
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Security Settings (recommended for production)
# Set these to 'true' when using HTTPS
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# HSTS settings (HTTP Strict Transport Security) - for production only
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DJANGO_LOG_LEVEL=INFO
