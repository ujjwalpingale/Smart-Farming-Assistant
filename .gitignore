# ─── Secrets & Environment ────────────────────────────────────────────────────
# Never commit the real .env — only .env.example belongs in source control.
.env
# (keep) .env.example

# ─── ML Model Artefacts ───────────────────────────────────────────────────────
# Large binary files should be stored in DVC / Git LFS, not plain git.
# Uncomment the lines below if you move model files to remote storage.
# ml_models/**/*.pkl
# ml_models/**/*.h5
# ml_models/**/*.npy

